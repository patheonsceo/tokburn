{
  "manifest_version": 3,
  "name": "tokburn",
  "version": "1.0.0",
  "description": "See your Claude token usage in real-time. Fully local, zero tracking.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["*://claude.ai/*"],
    "js": ["content-script.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [{
    "resources": ["interceptor.js", "styles.css"],
    "matches": ["*://claude.ai/*"]
  }]
}
